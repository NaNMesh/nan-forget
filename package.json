{
  "name": "nan-forget",
  "version": "0.6.5",
  "mcpName": "io.github.NaNMesh/nan-forget",
  "description": "Long-term memory for AI coding tools. Your AI remembers decisions, preferences, and context across sessions — automatically.",
  "repository": {
    "type": "git",
    "url": "https://github.com/NaNMesh/nan-forget.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nan-forget": "./bin/nan-forget.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/index.ts",
    "setup": "tsx src/setup/index.ts",
    "serve": "tsx src/mcp/server.ts",
    "clean": "tsx src/cli/index.ts clean",
    "stats": "tsx src/cli/index.ts stats"
  },
  "keywords": [
    "mcp",
    "memory",
    "llm",
    "sqlite",
    "claude",
    "ai-memory",
    "long-term-memory",

# NaN Forget Configuration
# Copy this file to .env and fill in your values

# ── Embedding Provider ──────────────────────────────────
# Default: ollama (free, local, recommended for Claude Code)
# Set to "openai" if using non-Claude LLMs or prefer cloud embeddings
NAN_FORGET_EMBEDDING_PROVIDER=ollama

# Only needed if using OpenAI embeddings
# OPENAI_API_KEY=sk-...

# ── Qdrant ──────────────────────────────────────────────
# Default: http://localhost:6333 (via docker compose up -d)
# NAN_FORGET_QDRANT_URL=http://localhost:6333

# ── User / Project ──────────────────────────────────────
# All sessions sharing the same user ID share memory
NAN_FORGET_USER_ID=default

# Root directory for MEMORY.md (defaults to current working directory)
# NAN_FORGET_PROJECT_ROOT=.
